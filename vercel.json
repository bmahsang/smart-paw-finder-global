{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": "dist",
  "framework": "vite",
  "crons": [
    {
      "path": "/api/slack-report",
      "schedule": "0 0 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' https: data:; font-src 'self' https://fonts.gstatic.com https: data:; connect-src 'self' https://api.line.me https://access.line.me https://page.line.me https://www.google-analytics.com https://www.googletagmanager.com https://zipcloud.ibsnet.co.jp https://graph.facebook.com; frame-src 'none'; object-src 'none'; base-uri 'self';"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/shopify", "destination": "/api/shopify" },
    { "source": "/api/line-callback", "destination": "/api/line-callback" },
    { "source": "/api/wishlist", "destination": "/api/wishlist" },
    { "source": "/api/slack-report", "destination": "/api/slack-report" },
    { "source": "/api/cancel-order", "destination": "/api/cancel-order" },
    { "source": "/api/b2b-apply", "destination": "/api/b2b?action=apply" },
    { "source": "/api/b2b-list", "destination": "/api/b2b?action=list" },
    { "source": "/api/b2b-detail", "destination": "/api/b2b?action=detail" },
    { "source": "/api/b2b-approve", "destination": "/api/b2b?action=approve" },
    { "source": "/api/b2b-status", "destination": "/api/b2b?action=status" },
    { "source": "/api/instagram-reels", "destination": "/api/instagram-reels" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
