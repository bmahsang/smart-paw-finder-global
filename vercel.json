{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": "dist",
  "framework": "vite",
  "crons": [
    {
      "path": "/api/slack-report",
      "schedule": "0 0 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com; style-src 'self' 'unsafe-inline'; img-src 'self' https: data:; font-src 'self' https: data:; connect-src 'self' https://api.line.me https://access.line.me https://page.line.me https://www.google-analytics.com https://www.googletagmanager.com https://zipcloud.ibsnet.co.jp; frame-src 'none'; object-src 'none'; base-uri 'self';"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/shopify", "destination": "/api/shopify" },
    { "source": "/api/line-callback", "destination": "/api/line-callback" },
    { "source": "/api/wishlist", "destination": "/api/wishlist" },
    { "source": "/api/slack-report", "destination": "/api/slack-report" },
    { "source": "/api/cancel-order", "destination": "/api/cancel-order" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
